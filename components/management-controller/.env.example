# Copy to `.env` at the repository root (or in the directory you run `node` from;
# the app walks up from the current working directory to find `.env`).
# Values in the real environment take precedence over this file.

# --- PostgreSQL (used by node-pg; see management-controller `db.js`) ---
PGHOST=
PGDATABASE=

# App role passwords (see `scripts/db-setup.sql` / database setup)
APP_USER_PASSWORD=
APP_SYSTEM_PASSWORD=

# --- Management controller (local / standalone) ---
# When set, runs against the kube context instead of in-cluster (see `mc-main.js`)
SKX_STANDALONE_NAMESPACE=

# Session signing (see `mc-apiserver.js`)
VMS_SESSION_SECRET=

# Set to "production" to serve static console, anything else/leave blank to serve live updates
NODE_ENV=
