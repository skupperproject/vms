{{- $pg := .Values.postgres | required "environment must define postgres (values/common.yaml)" }}

image:
  pullPolicy: IfNotPresent

postgres:
  host: {{ $pg.host | quote }}
  port: {{ $pg.port | quote }}
  user: {{ $pg.user | quote }}
  password: {{ $pg.password | quote }}
  database: {{ $pg.database | quote }}
